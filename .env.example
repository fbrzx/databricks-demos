# Copy to .env and fill in. Used for LOCAL development only.
# On Databricks Apps these are provided by the platform (Genie Space resource
# + the app's service principal), so you do NOT set them there.

# ---- Required: which Databricks workspace + Genie Space the app queries ----
# Easiest option: paste the full Genie room URL. The app derives
# DATABRICKS_HOST and GENIE_SPACE_ID from it.
GENIE_SPACE_URL=

# Or set these directly instead of GENIE_SPACE_URL.
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# GENIE_SPACE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# `make auth-login` also uses DATABRICKS_HOST when it is set.

# ---- Databricks authentication (pick ONE method) ----
# The Databricks SDK uses its default credential chain.
#
# Option A (recommended): run `databricks auth login --host <host>` instead of
# setting these, which writes a profile to ~/.databrickscfg. If you used a
# non-default profile name, point the SDK at it:
# DATABRICKS_CONFIG_PROFILE=your-profile-name
#
# If Databricks CLI v1.0+ reports "stored credentials from older CLI versions
# are no longer used", re-run `databricks auth login` for the profile, or use
# this local fallback while you migrate old CLI credentials:
# DATABRICKS_AUTH_STORAGE=plaintext
#
# Option B: personal access token (Settings > Developer > Access tokens).
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_TOKEN=dapixxxxxxxxxxxxxxxxxxxxxxxx

# ---- Optional tuning ----
# Max rows pulled from a Genie query result (single result chunk).
# GENIE_MAX_ROWS=10000

# Starter cards are cached in memory. By default startup uses the curated
# fallback cards and does not spend a Genie request. You can refresh manually
# with POST /api/suggestions/refresh, or opt into startup refresh:
# GENIE_STARTERS_REFRESH_ON_STARTUP=false
# GENIE_STARTERS_LIMIT=8
#
# To pin starters manually, paste a JSON array here or point at a JSON file.
# Each starter should include title, description, prompt, visual_type, and
# preferred_export. `required_columns` is optional.
# GENIE_STARTERS_JSON='[{"title":"Revenue trend","description":"Monthly revenue movement.","prompt":"Show revenue by month for the latest 12 complete months.","visual_type":"line","preferred_export":"pptx","required_columns":["month","revenue"]}]'
# GENIE_STARTERS_FILE=./starters.json
